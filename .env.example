# ========== Environment & Logging ==========
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_STORAGE_FOLDER=logs
LOG_CONSOLE_OUTPUT=true

# ========== Ollama Provider ==========
# Base URL where Ollama is running
OLLAMA_BASE_URL=http://localhost:11434

# Timeout for Ollama requests (in seconds)
OLLAMA_TIMEOUT=300

# Default model to use (can be overridden per request)
OLLAMA_DEFAULT_MODEL=llama2

# ========== LLM Settings ==========
# Maximum tokens in conversation context
MAX_CONTEXT_TOKENS=4096

# Safety margin for output generation
TOKEN_SAFETY_MARGIN=100

# ========== HTTP Request Configuration ==========
# Timeout for general HTTP requests (in seconds)
REQUEST_TIMEOUT=60

# Number of retries on failure
MAX_RETRIES=3

# Delay between retries (in seconds)
RETRY_DELAY=1.0

